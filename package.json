{
    "name": "spademo-monorepo",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": ">=20.0.0"
    },
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev -w @spademo/api\" \"npm run dev -w @spademo/web\"",
        "build": "npm run build --workspaces",
        "start": "echo 'Run from specific workspace via Dokploy command'",
        "install:all": "npm install",
        "seed": "npm run seed -w @spademo/api"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}